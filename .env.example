# Local dev only — fill in and rename to .env (gitignored).
# Production values live as Render env vars.

DATABASE_URL=postgres://user:pass@localhost:5432/persona_followup

PORT=3000

# Admin login credentials for the cookie-based session flow. Server
# refuses to start without these — pick a real username/password and
# rotate by editing here (locally) or in the Render dashboard (prod)
# then restarting.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me
