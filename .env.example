# Local dev only — fill in and rename to .env (gitignored).
# Production values live as Render env vars.

DATABASE_URL=postgres://user:pass@localhost:5432/persona_followup

# Twilio (Programmable Messaging API key, NOT the auth token)
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SID=SKxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_API_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# Sandbox sender (default). Override only when using a registered Business sender.
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# SendGrid
SENDGRID_API_KEY=SG.xxxxxxxxxxxxxxxxxxxxx.yyyyyyyyyyyyyyyyyyyy
# Must be a verified Single Sender Identity on SendGrid
SENDGRID_FROM=verified-sender@yourdomain.com

# Trial-mode overrides — route ALL outbound messages to these for testing.
# Leave blank in production to send to real lead/counsellor addresses.
TEST_RECIPIENT_EMAIL=test@yourdomain.com
TEST_RECIPIENT_WHATSAPP=14155550100

PORT=3000

# Optional Twilio webhook signature validation. Set together with PUBLIC_BASE_URL.
TWILIO_AUTH_TOKEN=

# Public-facing base URL — used for Twilio status callbacks + signature URL.
# Example: https://your-service.onrender.com
PUBLIC_BASE_URL=

# Anthropic API key — powers the staff_advanced "auto-extract actionables"
# button. Without it, the button surfaces a clear "API not configured" error
# but everything else continues to work.
ANTHROPIC_API_KEY=
